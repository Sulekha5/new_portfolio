<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alka Dhaked — Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700;800&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #050810;
    --bg2: #070c18;
    --panel: #0b1220;
    --border: #1a2540;
    --accent: #00f5a0;
    --accent2: #00c8ff;
    --accent3: #f72585;
    --gold: #ffd60a;
    --text: #c9d6f0;
    --muted: #4a5a7a;
    --font-mono: 'JetBrains Mono', monospace;
    --font-display: 'Syne', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: var(--bg); color: var(--text); font-family: var(--font-mono); overflow-x: hidden; cursor: none; }

  /* CURSOR */
  .cursor { width: 10px; height: 10px; background: var(--accent); border-radius: 50%; position: fixed; pointer-events: none; z-index: 10000; transform: translate(-50%,-50%); box-shadow: 0 0 16px var(--accent); transition: background 0.2s; }
  .cursor-ring { width: 40px; height: 40px; border: 1.5px solid rgba(0,245,160,0.6); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9999; transform: translate(-50%,-50%); transition: all 0.15s ease; }

  /* SCROLL BAR */
  .scroll-bar { position: fixed; top: 0; left: 0; height: 2px; background: linear-gradient(90deg, var(--accent), var(--accent2), var(--accent3)); z-index: 200; width: 0; }

  /* BG CANVAS */
  #bg-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; opacity: 0.3; }

  /* PARTICLES */
  .particle { position: fixed; pointer-events: none; border-radius: 50%; animation: float-up 6s linear infinite; z-index: 0; }
  @keyframes float-up { 0% { opacity: 0; transform: translateY(100vh) scale(0); } 10% { opacity: 0.6; } 90% { opacity: 0.2; } 100% { opacity: 0; transform: translateY(-20px) scale(1); } }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 16px 48px;
    background: rgba(5,8,16,0.8); backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    transition: all 0.3s;
  }
  .nav-logo { font-family: var(--font-display); font-weight: 800; font-size: 1.1rem; color: var(--accent); text-decoration: none; letter-spacing: 0.05em; }
  .nav-logo span { color: #fff; }
  .nav-links { display: flex; gap: 32px; list-style: none; }
  .nav-links a { color: var(--muted); text-decoration: none; font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; transition: color 0.2s; position: relative; }
  .nav-links a::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 1px; background: var(--accent); transition: width 0.25s; }
  .nav-links a:hover { color: var(--accent); }
  .nav-links a:hover::after { width: 100%; }

  section { position: relative; z-index: 1; }

  /* ═══ HERO ═══ */
  #hero {
    min-height: 100vh; display: flex; align-items: center;
    padding: 100px 8vw 60px; gap: 60px; position: relative; overflow: hidden;
  }
  .hero-glow {
    position: absolute; width: 600px; height: 600px; border-radius: 50%;
    background: radial-gradient(ellipse, rgba(0,245,160,0.06) 0%, transparent 70%);
    top: 50%; left: 50%; transform: translate(-50%,-50%);
    animation: pulse-glow 4s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes pulse-glow { 0%,100%{ opacity: 0.5; transform: translate(-50%,-50%) scale(1); } 50%{ opacity: 1; transform: translate(-50%,-50%) scale(1.1); } }

  .hero-left { flex: 1; z-index: 1; }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--accent); border: 1px solid rgba(0,245,160,0.3);
    padding: 6px 14px; margin-bottom: 28px;
    animation: fadeUp 0.8s ease both;
  }
  .blink-dot { width: 6px; height: 6px; background: var(--accent); border-radius: 50%; animation: blink 1s infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
  .hero-name {
    font-family: var(--font-display); font-size: clamp(3rem, 7vw, 6.5rem);
    font-weight: 800; line-height: 1.0; letter-spacing: -0.03em;
    animation: fadeUp 0.9s 0.1s ease both;
  }
  .hero-name .n1 { display: block; color: #fff; }
  .hero-name .n2 { display: block; background: linear-gradient(135deg, var(--accent), var(--accent2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .hero-sub { font-size: 0.83rem; color: var(--muted); margin-top: 20px; line-height: 1.8; max-width: 500px; animation: fadeUp 1s 0.2s ease both; }
  .hero-sub .hl { color: var(--accent2); }
  .hero-sub .hl2 { color: var(--accent); }
  .hero-btns { display: flex; gap: 14px; margin-top: 40px; animation: fadeUp 1.1s 0.3s ease both; flex-wrap: wrap; }
  .btn-p {
    background: linear-gradient(135deg, var(--accent), #00c8a0);
    color: #000; font-family: var(--font-mono); font-weight: 700;
    font-size: 0.75rem; letter-spacing: 0.1em; padding: 13px 26px;
    border: none; cursor: none; text-decoration: none;
    display: inline-flex; align-items: center; gap: 8px;
    clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
    transition: all 0.25s; position: relative; overflow: hidden;
  }
  .btn-p::before { content: ''; position: absolute; inset: 0; background: rgba(255,255,255,0.15); transform: translateX(-100%); transition: transform 0.3s; }
  .btn-p:hover::before { transform: translateX(0); }
  .btn-p:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(0,245,160,0.4); }
  .btn-s { border: 1px solid rgba(0,200,255,0.4); color: var(--accent2); font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.1em; padding: 13px 22px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: all 0.25s; }
  .btn-s:hover { border-color: var(--accent2); background: rgba(0,200,255,0.05); transform: translateY(-2px); }
  .btn-g { border: 1px solid var(--border); color: var(--text); font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.1em; padding: 13px 22px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: all 0.25s; }
  .btn-g:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

  .hero-stats { display: flex; gap: 48px; margin-top: 56px; padding-top: 32px; border-top: 1px solid var(--border); animation: fadeUp 1.2s 0.4s ease both; }
  .stat-num { font-family: var(--font-display); font-size: 2.2rem; font-weight: 800; background: linear-gradient(135deg, var(--accent), var(--accent2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .stat-lbl { font-size: 0.6rem; color: var(--muted); letter-spacing: 0.15em; text-transform: uppercase; margin-top: 4px; }

  /* PHOTO 3D */
  .hero-right { flex: 0 0 380px; height: 420px; display: flex; align-items: center; justify-content: center; z-index: 1; animation: fadeUp 1s 0.3s ease both; }
  .photo-scene { width: 300px; height: 360px; perspective: 1000px; }
  .photo-card {
    width: 100%; height: 100%; position: relative;
    transform-style: preserve-3d;
    transition: transform 0.1s ease;
    animation: float3d 6s ease-in-out infinite;
  }
  @keyframes float3d { 0%,100%{transform: translateY(0) rotateX(0deg) rotateY(0deg);} 25%{transform: translateY(-12px) rotateX(3deg) rotateY(-3deg);} 50%{transform: translateY(-6px) rotateX(-2deg) rotateY(4deg);} 75%{transform: translateY(-16px) rotateX(2deg) rotateY(-2deg);} }
  .photo-frame {
    position: absolute; inset: 0;
    border: 2px solid transparent;
    background: linear-gradient(var(--bg2), var(--bg2)) padding-box,
                linear-gradient(135deg, var(--accent), var(--accent2), var(--accent3)) border-box;
    overflow: hidden;
    box-shadow: 0 0 60px rgba(0,245,160,0.15), 0 30px 80px rgba(0,0,0,0.5), inset 0 0 30px rgba(0,245,160,0.03);
  }
  .photo-frame img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
  .photo-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(5,8,16,0.8) 100%);
    pointer-events: none;
  }
  .photo-badge {
    position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
    background: rgba(0,245,160,0.1); border: 1px solid rgba(0,245,160,0.3);
    backdrop-filter: blur(10px); padding: 8px 20px;
    font-size: 0.65rem; color: var(--accent); letter-spacing: 0.15em; text-transform: uppercase;
    white-space: nowrap;
  }
  .photo-glow1 {
    position: absolute; width: 200px; height: 200px; border-radius: 50%;
    background: radial-gradient(ellipse, rgba(0,245,160,0.2) 0%, transparent 70%);
    top: -80px; right: -60px; animation: orb1 4s ease-in-out infinite;
  }
  .photo-glow2 {
    position: absolute; width: 150px; height: 150px; border-radius: 50%;
    background: radial-gradient(ellipse, rgba(0,200,255,0.2) 0%, transparent 70%);
    bottom: -60px; left: -50px; animation: orb2 5s ease-in-out infinite;
  }
  .photo-glow3 {
    position: absolute; width: 100px; height: 100px; border-radius: 50%;
    background: radial-gradient(ellipse, rgba(247,37,133,0.15) 0%, transparent 70%);
    top: 40%; right: -50px; animation: orb3 3.5s ease-in-out infinite;
  }
  @keyframes orb1 { 0%,100%{transform: translate(0,0) scale(1);} 50%{transform: translate(-10px,15px) scale(1.1);} }
  @keyframes orb2 { 0%,100%{transform: translate(0,0);} 50%{transform: translate(10px,-10px) scale(1.15);} }
  @keyframes orb3 { 0%,100%{transform: translate(0,0);} 50%{transform: translate(-8px,12px);} }
  .corner-decor {
    position: absolute; width: 18px; height: 18px;
    border-color: var(--accent); border-style: solid;
  }
  .corner-tl { top: -2px; left: -2px; border-width: 2px 0 0 2px; }
  .corner-tr { top: -2px; right: -2px; border-width: 2px 2px 0 0; }
  .corner-bl { bottom: -2px; left: -2px; border-width: 0 0 2px 2px; }
  .corner-br { bottom: -2px; right: -2px; border-width: 0 2px 2px 0; }

  @keyframes fadeUp { from{ opacity:0; transform: translateY(32px); } to{ opacity:1; transform: translateY(0); } }

  /* SECTIONS */
  .sec-tag { display: inline-flex; align-items: center; gap: 8px; font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); border: 1px solid rgba(0,245,160,0.25); padding: 4px 12px; }
  .sec-line { flex: 1; height: 1px; background: linear-gradient(90deg, var(--border), transparent); }
  .sec-header { display: flex; align-items: center; gap: 20px; margin-bottom: 60px; }
  .sec-title { font-family: var(--font-display); font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 800; color: #fff; }
  .sec-desc { font-size: 0.8rem; color: var(--muted); line-height: 1.8; }

  /* ABOUT */
  #about { padding: 120px 8vw; }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .terminal-card { background: var(--panel); border: 1px solid var(--border); padding: 36px; position: relative; overflow: hidden; }
  .terminal-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--accent), var(--accent2), var(--accent3)); }
  .terminal-header { display: flex; align-items: center; gap: 8px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
  .t-dot { width: 10px; height: 10px; border-radius: 50%; }
  .t-dot.r { background: #ff5f56; } .t-dot.y { background: #ffbd2e; } .t-dot.g { background: #27c93f; }
  .t-title { font-size: 0.65rem; color: var(--muted); margin-left: 8px; letter-spacing: 0.1em; }
  .t-line { display: flex; gap: 10px; margin-bottom: 10px; font-size: 0.77rem; line-height: 1.6; }
  .t-prompt { color: var(--accent); } .t-key { color: var(--accent2); } .t-eq { color: var(--muted); }
  .t-val { color: var(--text); } .t-str { color: #a8d8b0; }
  .currently-box { margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border); }
  .curr-item { font-size: 0.76rem; color: var(--muted); line-height: 2; display: flex; align-items: center; gap: 8px; }
  .curr-item::before { content: '→'; color: var(--accent); }

  /* SKILLS */
  #skills { padding: 120px 8vw; background: var(--bg2); }
  .skills-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 18px; }
  .sk-card { background: var(--panel); border: 1px solid var(--border); padding: 28px; position: relative; overflow: hidden; transition: all 0.3s; }
  .sk-card::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at top left, rgba(0,245,160,0.04), transparent 70%); pointer-events: none; }
  .sk-card:hover { border-color: rgba(0,245,160,0.4); transform: translateY(-5px); box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
  .sk-cat { font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }
  .sk-cat::before { content: ''; width: 18px; height: 1px; background: var(--accent); }
  .sk-icon { font-size: 1.8rem; margin-bottom: 10px; display: block; }
  .sk-title { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 14px; }
  .tags { display: flex; flex-wrap: wrap; gap: 7px; }
  .tag { font-size: 0.62rem; background: rgba(0,245,160,0.06); border: 1px solid rgba(0,245,160,0.18); color: var(--accent); padding: 3px 10px; }
  .tag.b { background: rgba(0,200,255,0.06); border-color: rgba(0,200,255,0.2); color: var(--accent2); }
  .tag.p { background: rgba(247,37,133,0.06); border-color: rgba(247,37,133,0.2); color: var(--accent3); }

  /* EXPERIENCE */
  #experience { padding: 120px 8vw; }
  .timeline { position: relative; padding-left: 28px; }
  .timeline::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 1px; background: linear-gradient(to bottom, var(--accent), var(--accent2), transparent); }
  .exp-item { position: relative; margin-bottom: 56px; padding-left: 32px; }
  .exp-item::before { content: ''; position: absolute; left: -33px; top: 8px; width: 10px; height: 10px; background: var(--accent); border-radius: 50%; box-shadow: 0 0 20px var(--accent); }
  .exp-period { font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }
  .exp-title { font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: #fff; margin-bottom: 4px; }
  .exp-co { font-size: 0.75rem; color: var(--accent2); margin-bottom: 14px; }
  .exp-bullets { list-style: none; }
  .exp-bullets li { font-size: 0.78rem; color: var(--muted); line-height: 1.8; padding-left: 18px; position: relative; margin-bottom: 4px; }
  .exp-bullets li::before { content: '→'; position: absolute; left: 0; color: var(--accent); font-size: 0.7rem; }

  /* PROJECTS */
  #projects { padding: 120px 8vw; background: var(--bg2); }
  .proj-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 22px; }
  .proj-card { background: var(--panel); border: 1px solid var(--border); padding: 30px; position: relative; overflow: hidden; display: flex; flex-direction: column; transition: all 0.3s; }
  .proj-card::before { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 1px; background: linear-gradient(90deg, transparent, var(--accent), transparent); transition: left 0.5s; }
  .proj-card:hover::before { left: 100%; }
  .proj-card:hover { border-color: rgba(0,245,160,0.35); transform: translateY(-6px); box-shadow: 0 24px 70px rgba(0,0,0,0.4); }
  .proj-num { font-family: var(--font-display); font-size: 3.5rem; font-weight: 800; color: rgba(0,245,160,0.07); position: absolute; top: 12px; right: 16px; line-height: 1; }
  .proj-icon { font-size: 1.8rem; margin-bottom: 14px; }
  .proj-title { font-family: var(--font-display); font-size: 1.05rem; font-weight: 700; color: #fff; margin-bottom: 10px; }
  .proj-desc { font-size: 0.77rem; color: var(--muted); line-height: 1.8; flex: 1; margin-bottom: 18px; }
  .proj-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; flex-wrap: wrap; gap: 10px; }
  .proj-link { font-size: 0.68rem; color: var(--accent); text-decoration: none; letter-spacing: 0.1em; display: flex; align-items: center; gap: 6px; border-bottom: 1px solid transparent; transition: border-color 0.2s; }
  .proj-link:hover { border-color: var(--accent); }
  .p-stack { display: flex; gap: 6px; flex-wrap: wrap; }
  .p-tag { font-size: 0.6rem; background: rgba(0,245,160,0.05); border: 1px solid rgba(0,245,160,0.15); color: var(--accent); padding: 2px 8px; }

  /* EDUCATION */
  #education { padding: 120px 8vw; }
  .edu-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
  .edu-card { background: var(--panel); border: 1px solid var(--border); padding: 32px; position: relative; overflow: hidden; transition: border-color 0.25s; }
  .edu-card:hover { border-color: rgba(0,245,160,0.4); }
  .edu-bg { position: absolute; bottom: -20px; right: -10px; font-family: var(--font-display); font-size: 5rem; font-weight: 800; color: rgba(0,245,160,0.04); line-height: 1; pointer-events: none; }
  .edu-period { font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; }
  .edu-degree { font-family: var(--font-display); font-size: 1.05rem; font-weight: 700; color: #fff; margin-bottom: 6px; }
  .edu-inst { font-size: 0.75rem; color: var(--accent2); margin-bottom: 12px; }
  .edu-score { display: inline-flex; align-items: center; gap: 8px; font-size: 0.7rem; color: var(--gold); background: rgba(255,214,10,0.07); border: 1px solid rgba(255,214,10,0.2); padding: 4px 12px; }

  /* ACHIEVEMENTS */
  #achievements { padding: 120px 8vw; background: var(--bg2); }
  .ach-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; }
  .ach-card { background: var(--panel); border: 1px solid var(--border); padding: 28px; position: relative; overflow: hidden; transition: all 0.25s; }
  .ach-card:hover { border-color: rgba(0,245,160,0.4); transform: scale(1.02); }
  .ach-badge { position: absolute; top: 16px; right: 16px; font-size: 0.55rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); border: 1px solid rgba(255,214,10,0.3); padding: 3px 8px; }
  .ach-icon { font-size: 2rem; margin-bottom: 14px; }
  .ach-title { font-family: var(--font-display); font-size: 0.95rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
  .ach-val { font-size: 0.77rem; color: var(--muted); line-height: 1.7; }
  .ach-val strong { color: var(--accent); }

  /* CERTS */
  #certs { padding: 80px 8vw; }
  .certs-row { display: flex; gap: 18px; flex-wrap: wrap; }
  .cert-card { flex: 1; min-width: 260px; background: var(--panel); border: 1px solid var(--border); padding: 24px; display: flex; align-items: center; gap: 18px; transition: all 0.25s; position: relative; overflow: hidden; }
  .cert-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: linear-gradient(to bottom, var(--accent), var(--accent2)); }
  .cert-card:hover { border-color: rgba(0,245,160,0.35); transform: translateY(-3px); }
  .cert-icon { font-size: 2rem; flex-shrink: 0; }
  .cert-name { font-family: var(--font-display); font-size: 0.9rem; font-weight: 700; color: #fff; margin-bottom: 4px; }
  .cert-by { font-size: 0.68rem; color: var(--accent2); }

  /* CONTACT */
  #contact { padding: 140px 8vw; text-align: center; }
  .contact-inner { max-width: 680px; margin: 0 auto; }
  .contact-title { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; color: #fff; margin-bottom: 16px; }
  .contact-title span { background: linear-gradient(135deg, var(--accent), var(--accent2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .contact-sub { font-size: 0.8rem; color: var(--muted); line-height: 1.9; margin-bottom: 48px; }
  .contact-links { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; }
  .c-link { display: flex; align-items: center; gap: 10px; background: var(--panel); border: 1px solid var(--border); color: var(--text); text-decoration: none; font-size: 0.73rem; padding: 14px 22px; transition: all 0.25s; letter-spacing: 0.05em; }
  .c-link:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0,245,160,0.1); }

  footer { border-top: 1px solid var(--border); padding: 24px 8vw; display: flex; justify-content: space-between; align-items: center; font-size: 0.63rem; color: var(--muted); letter-spacing: 0.08em; }
  footer span { color: var(--accent); }

  /* DSA CANVAS */
  #dsa-canvas { width: 100%; height: 100%; }

  /* GLITCH */
  .glitch { position: relative; }
  .glitch::before, .glitch::after { content: attr(data-text); position: absolute; top: 0; left: 0; background: linear-gradient(135deg, var(--accent), var(--accent2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
