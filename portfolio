<script>
// ═══ CURSOR ═══
const cursor = document.getElementById('cursor');
const ring = document.getElementById('cursorRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove', e=>{mx=e.clientX;my=e.clientY;});
(function animC(){
  cursor.style.left=mx+'px'; cursor.style.top=my+'px';
  rx+=(mx-rx)*0.13; ry+=(my-ry)*0.13;
  ring.style.left=rx+'px'; ring.style.top=ry+'px';
  requestAnimationFrame(animC);
})();
document.querySelectorAll('a,button').forEach(el=>{
  el.addEventListener('mouseenter',()=>{ring.style.transform='translate(-50%,-50%) scale(1.7)';ring.style.opacity='0.9';});
  el.addEventListener('mouseleave',()=>{ring.style.transform='translate(-50%,-50%) scale(1)';ring.style.opacity='0.6';});
});

// ═══ SCROLL BAR ═══
window.addEventListener('scroll',()=>{
  const pct=window.scrollY/(document.body.scrollHeight-window.innerHeight)*100;
  document.getElementById('scrollBar').style.width=pct+'%';
});

// ═══ 3D PHOTO TILT ═══
const scene = document.getElementById('photoScene');
const card = document.getElementById('photoCard');
if(scene && card){
  scene.addEventListener('mousemove', e=>{
    const r = scene.getBoundingClientRect();
    const x = (e.clientX - r.left) / r.width - 0.5;
    const y = (e.clientY - r.top) / r.height - 0.5;
    card.style.transform = `rotateY(${x*20}deg) rotateX(${-y*15}deg) translateY(${y*-8}px)`;
    card.style.animation = 'none';
  });
  scene.addEventListener('mouseleave', ()=>{
    card.style.transform = '';
    card.style.animation = 'float3d 6s ease-in-out infinite';
  });
}

// ═══ BG GRAPH ═══
const bgC = document.getElementById('bg-canvas');
const bgCtx = bgC.getContext('2d');
let bW,bH,nodes=[];
function resizeBg(){ bW=bgC.width=window.innerWidth; bH=bgC.height=window.innerHeight; }
resizeBg(); window.addEventListener('resize',resizeBg);
for(let i=0;i<60;i++) nodes.push({x:Math.random()*bW,y:Math.random()*bH,vx:(Math.random()-.5)*0.35,vy:(Math.random()-.5)*0.35,r:Math.random()*2+1});
(function drawBg(){
  bgCtx.clearRect(0,0,bW,bH);
  nodes.forEach(n=>{n.x+=n.vx;n.y+=n.vy;if(n.x<0||n.x>bW)n.vx*=-1;if(n.y<0||n.y>bH)n.vy*=-1;});
  for(let i=0;i<nodes.length;i++) for(let j=i+1;j<nodes.length;j++){
    const dx=nodes[i].x-nodes[j].x,dy=nodes[i].y-nodes[j].y,d=Math.sqrt(dx*dx+dy*dy);
    if(d<190){
      bgCtx.beginPath();bgCtx.moveTo(nodes[i].x,nodes[i].y);bgCtx.lineTo(nodes[j].x,nodes[j].y);
      bgCtx.strokeStyle=`rgba(0,245,160,${0.12*(1-d/190)})`;bgCtx.lineWidth=0.6;bgCtx.stroke();
    }
  }
  nodes.forEach(n=>{
    bgCtx.beginPath();bgCtx.arc(n.x,n.y,n.r,0,Math.PI*2);
    bgCtx.fillStyle='rgba(0,245,160,0.5)';bgCtx.fill();
  });
  requestAnimationFrame(drawBg);
})();

// ═══ CURSOR PARTICLES ON CLICK ═══
document.addEventListener('click', e=>{
  for(let i=0;i<8;i++){
    const p=document.createElement('div');
    p.style.cssText=`position:fixed;width:${Math.random()*6+3}px;height:${Math.random()*6+3}px;
      background:var(--accent);border-radius:50%;left:${e.clientX}px;top:${e.clientY}px;
      pointer-events:none;z-index:9998;transition:all 0.8s ease;`;
    document.body.appendChild(p);
    const ang=Math.random()*Math.PI*2,dist=40+Math.random()*60;
    setTimeout(()=>{p.style.left=(e.clientX+Math.cos(ang)*dist)+'px';p.style.top=(e.clientY+Math.sin(ang)*dist)+'px';p.style.opacity='0';},10);
    setTimeout(()=>p.remove(),900);
  }
});

// ═══ SCROLL REVEAL ═══
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');});
},{threshold:0.1});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

// ═══ FLOATING PARTICLES ═══
const colors=['rgba(0,245,160,', 'rgba(0,200,255,', 'rgba(247,37,133,'];
for(let i=0;i<15;i++){
  const p=document.createElement('div');
  const c=colors[Math.floor(Math.random()*3)];
  const s=Math.random()*4+2;
  p.className='particle';
  p.style.cssText=`width:${s}px;height:${s}px;background:${c}${0.3+Math.random()*0.4});
    left:${Math.random()*100}%;animation-delay:${Math.random()*6}s;animation-duration:${6+Math.random()*6}s;`;
  document.body.appendChild(p);
}

// ═══ TYPING EFFECT for terminal ═══
const lines = document.querySelectorAll('.t-line');
lines.forEach((line, i) => {
  line.style.opacity = '0';
  line.style.transition = 'opacity 0.3s ease';
  setTimeout(() => { line.style.opacity = '1'; }, 300 + i * 150);
});
</script>
